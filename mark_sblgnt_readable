  <style>
    :root {
      --bg: #f7f4ee;
      --paper: #fffdf8;
      --ink: #222;
      --muted: #6b655d;
      --line: #e6ded2;
      --accent: #6a4b2f;
      --shadow: 0 8px 24px rgba(0,0,0,.06);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Georgia", "Times New Roman", serif;
      background: linear-gradient(180deg, #f3efe8 0%, #faf8f4 100%);
      color: var(--ink);
      line-height: 1.6;
    }
    .wrap {
      max-width: 980px;
      margin: 0 auto;
      padding: 40px 20px 64px;
    }
    header {
      text-align: center;
      margin-bottom: 32px;
      padding: 28px 24px;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
    }
    h1 {
      margin: 0;
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      letter-spacing: .03em;
    }
    .subtitle {
      margin-top: 10px;
      color: var(--muted);
      font-size: .98rem;
    }
    .verse-block {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      margin: 0 0 18px;
      overflow: hidden;
    }
    .verse-block h2 {
      margin: 0;
      padding: 16px 20px;
      font-size: 1.15rem;
      background: #f1e9dc;
      border-bottom: 1px solid var(--line);
      color: var(--accent);
    }
    .notes {
      padding: 14px;
    }
    .note {
      white-space: pre-wrap;
      word-break: break-word;
      margin: 0 0 10px;
      padding: 12px 14px;
      background: #fff;
      border: 1px solid #ece4d8;
      border-radius: 12px;
      font-size: 1rem;
    }
    .note:last-child { margin-bottom: 0; }
    @media (max-width: 640px) {
      .wrap { padding: 20px 12px 40px; }
      header { padding: 20px 16px; }
      .verse-block h2 { padding: 14px 16px; }
      .notes { padding: 10px; }
      .note { padding: 10px 12px; font-size: .97rem; }
    }
  </style>
</head>
